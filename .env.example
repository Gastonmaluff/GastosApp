# Copiar a .env.local y completar para activar Firebase.
# Mientras estas variables no existan, la app usa datos mock + localStorage.
# En Firebase Authentication activar Email/Password.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_CAJA_WORKSPACE_ID=principal
